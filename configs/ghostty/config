shell-integration = fish
theme = Dark Modern

macos-titlebar-style = tabs
macos-icon = chalkboard

unfocused-split-opacity = 1

keybind = super+shift+arrow_up=goto_split:up
keybind = super+shift+arrow_down=goto_split:down
keybind = super+shift+arrow_left=goto_split:left
keybind = super+shift+arrow_right=goto_split:right

keybind = super+alt+arrow_left=previous_tab
keybind = super+alt+arrow_right=next_tab

link-url = true

window-save-state = always

shell-integration-features = ssh-terminfo
